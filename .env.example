# GitHub Models API 認証トークン
# 取得方法: GitHub Settings → Developer settings → Personal access tokens
# GitHub Actions では secrets.GITHUB_TOKEN が自動提供されるため不要
GITHUB_TOKEN=your_github_token_here

# note.com 非公開 API 認証トークン（Bearer）
# 取得方法: note.com にログイン → DevTools (F12) → Network タブ →
#   任意のリクエストの Authorization ヘッダーから取得
# 有効期限あり。期限切れ時は再取得が必要。
NOTE_API_TOKEN=your_note_api_token_here

# Unsplash 画像検索 API（任意）
# 取得方法: https://unsplash.com/developers → アプリ登録 → Access Key をコピー
# 未設定の場合、画像なしで記事生成が継続される（エラーにはならない）
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
